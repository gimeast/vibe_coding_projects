{
  "name": "stock-news-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "kill": "for /f \"tokens=5\" %a in ('netstat -aon ^| findstr :3001') do taskkill /PID %a /F 2>nul & for /f \"tokens=5\" %a in ('netstat -aon ^| findstr :5173') do taskkill /PID %a /F 2>nul",
    "dev:client": "vite",
    "dev:server": "nodemon --watch server --ignore server/data --ext js,mjs,cjs server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "iconv-lite": "^0.7.2",
    "node-cron": "^3.0.3",
    "puppeteer": "^22.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "jsdom": "^25.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
